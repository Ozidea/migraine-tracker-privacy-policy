<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Migraine Tracker hesap silme talebi ve destek sayfası."
    />
    <title>Migraine Tracker - Hesap Silme Talebi</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #eef7f2;
        --bg-2: #dfeee6;
        --card: rgba(255, 255, 255, 0.82);
        --card-border: rgba(33, 86, 58, 0.14);
        --text: #123321;
        --muted: #557063;
        --primary: #2d8d5e;
        --primary-2: #1f6f49;
        --danger: #b42318;
        --shadow: 0 24px 70px rgba(15, 52, 33, 0.14);
        --radius: 24px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system,
          BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, #ffffff 0, transparent 28%),
          radial-gradient(circle at top right, rgba(77, 204, 126, 0.18) 0, transparent 30%),
          linear-gradient(135deg, var(--bg) 0%, var(--bg-2) 100%);
      }

      .wrap {
        width: min(100%, 1080px);
        margin: 0 auto;
        padding: 40px 20px 56px;
      }

      .hero {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--card-border);
        border-radius: calc(var(--radius) + 8px);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.78));
        box-shadow: var(--shadow);
        padding: 36px;
      }

      .hero::before,
      .hero::after {
        content: "";
        position: absolute;
        border-radius: 999px;
        filter: blur(6px);
        pointer-events: none;
      }

      .hero::before {
        width: 220px;
        height: 220px;
        right: -80px;
        top: -90px;
        background: rgba(45, 141, 94, 0.13);
      }

      .hero::after {
        width: 180px;
        height: 180px;
        left: -70px;
        bottom: -80px;
        background: rgba(31, 111, 73, 0.1);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(45, 141, 94, 0.12);
        color: var(--primary-2);
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      h1 {
        margin: 18px 0 10px;
        font-size: clamp(30px, 4vw, 52px);
        line-height: 1.04;
